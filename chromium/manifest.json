{
  "manifest_version": 3,
  "name": "Stuff Grabber",
  "version": "1.0.2",
  "description": "Grabs HLS, DASH, direct video URLs, and page images; saves via helper tools",
  "permissions": [
    "webRequest",
    "nativeMessaging",
    "storage",
    "tabs",
    "scripting",
    "cookies",
    "alarms",
    "downloads",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "public/scripts/background.js"
  },
  "icons": {
    "16": "asset/icon-16.png",
    "32": "asset/icon-32.png",
    "48": "asset/icon-48.png",
    "128": "asset/icon-128.png"
  },
  "action": {
    "default_popup": "public/popup.html",
    "default_icon": {
      "16": "asset/icon-16.png",
      "32": "asset/icon-32.png",
      "48": "asset/icon-48.png",
      "128": "asset/icon-128.png"
    }
  },
  "options_ui": {
    "page": "public/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*",
        "file:///*"
      ],
      "js": [
        "public/scripts/ios-select.js",
        "public/scripts/theme-helpers.js",
        "public/scripts/social-post-urls.js",
        "public/scripts/download-progress.js",
        "public/scripts/yt-page-helpers.js",
        "public/scripts/ffmpeg-preset-helpers.js",
        "public/scripts/image-hover-download.js",
        "public/scripts/fab.js",
        "public/scripts/video-recorder.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "asset/icon-16.png",
        "asset/icon-32.png",
        "asset/icon-48.png",
        "asset/icon-128.png",
        "style/fab.css",
        "style/modal-theme.css",
        "style/ios-select.css"
      ],
      "matches": [
        "http://*/*",
        "https://*/*",
        "file:///*"
      ]
    }
  ]
}

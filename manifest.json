{
    "manifest_version": 3,
    "name": "Stuff Grabber",
    "version": "1.0",
    "description": "Grabs HLS, DASH, direct video URLs, and page images; saves via helper tools",
    "permissions": [
      "webRequest",
      "nativeMessaging",
      "storage",
      "tabs",
      "cookies",
      "alarms",
      "downloads",
      "contextMenus"
    ],
    "host_permissions": [
      "<all_urls>"
    ],
    "background": {
      "service_worker": "public/scripts/background.js"
    },
    "icons": {
      "16": "asset/icon-16.png",
      "32": "asset/icon-32.png",
      "48": "asset/icon-48.png",
      "128": "asset/icon-128.png"
    },
    "action": {
      "default_popup": "public/popup.html",
      "default_icon": {
        "16": "asset/icon-16.png",
        "32": "asset/icon-32.png",
        "48": "asset/icon-48.png",
        "128": "asset/icon-128.png"
      }
    },
    "options_ui": {
      "page": "public/options.html",
      "open_in_tab": true
    },
    "content_scripts": [
      {
        "matches": ["http://*/*", "https://*/*"],
        "js": ["public/scripts/yt-page-helpers.js", "public/scripts/fab.js", "public/scripts/image-hover-download.js"],
        "run_at": "document_idle"
      }
    ],
    "web_accessible_resources": [
      {
        "resources": ["asset/icon-16.png", "asset/icon-32.png", "asset/icon-48.png", "asset/icon-128.png", "style/fab.css"],
        "matches": ["http://*/*", "https://*/*"]
      }
    ]
  }